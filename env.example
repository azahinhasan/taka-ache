# Google Places API Key (Optional - for enhanced ATM coverage)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the Places API (New) in your Google Cloud Console
# Note: This is optional. The app works without it using OpenStreetMap data only.
GOOGLE_PLACES_API_KEY=your_api_key_here

# MongoDB Connection String (Required for ATM reviews feature)
# Get free MongoDB Atlas cluster: https://www.mongodb.com/cloud/atlas/register
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/atm-locator?retryWrites=true&w=majority

# CORS Allowed Origins (comma-separated list of allowed origins for API routes)
# Example: http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
